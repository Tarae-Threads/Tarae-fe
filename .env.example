# ---------------------------------------------------------------------------
# 타래(Tarae) 환경변수 예시
#
# 사용법: 이 파일을 `.env.local`로 복사한 뒤 실제 값으로 채워주세요.
#   cp .env.example .env.local
# ---------------------------------------------------------------------------

# 백엔드 API base URL (필수)
# 예: https://api.taraethreads.com
NEXT_PUBLIC_API_BASE_URL=

# 네이버 지도 Client ID (필수)
# 발급: NCP 콘솔 → Maps → Application → Web Dynamic Map
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=

# 네이버 지오코딩 API (서버사이드, /api/geocode 프록시에서 사용)
# 발급: NCP 콘솔 → API Gateway → Geocoding API
NCP_APIGW_API_KEY_ID=
NCP_APIGW_API_KEY=

# Google Analytics 4 측정 ID (선택)
# 예: G-XXXXXXXXXX. 비워두면 GA 스크립트 로드되지 않음.
NEXT_PUBLIC_GA_ID=
